# Copy this file to .env and fill in your values.
# Never commit .env to git.

# LLM provider API key — used by LangGraph agent via Cursor's OpenAI-compatible endpoint
OPENAI_API_KEY=your-openai-api-key-here

# Optional: override base URL for Cursor's proxy or a local model server
OPENAI_BASE_URL=

# MCP server host/port (defaults shown)
MCP_HOST=localhost
MCP_PORT=8765

# Blender executable path (used by utility scripts)
BLENDER_PATH=C:/Program Files/Blender Foundation/Blender 4.4/blender.exe
